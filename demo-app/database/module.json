{
  "name": "database",
  "version": "1.0.0",
  "description": "In-memory mock database. Single source of truth for all domain types and data access.",
  "files": ["db.client.ts"],
  "exports": {
    "db": "{ users, tasks, projects, notifications } — namespaced table clients",
    "db.users.findById": "(id: string) => User | null",
    "db.users.findByEmail": "(email: string) => User | null",
    "db.users.findAll": "() => User[]",
    "db.users.save": "(user: User) => User",
    "db.tasks.findById": "(id: string) => Task | null",
    "db.tasks.findByProject": "(projectId: string) => Task[]",
    "db.tasks.findByAssignee": "(userId: string) => Task[]",
    "db.tasks.save": "(task: Task) => Task",
    "db.tasks.delete": "(id: string) => boolean",
    "db.projects.findById": "(id: string) => Project | null",
    "db.projects.findAll": "() => Project[]",
    "db.projects.save": "(project: Project) => Project",
    "db.notifications.findByUser": "(userId: string) => Notification[]",
    "db.notifications.save": "(n: Notification) => Notification",
    "db.notifications.markRead": "(id: string) => void"
  },
  "imports": {},
  "types": {
    "User": "{ id, email, name, role: UserRole, createdAt }",
    "Task": "{ id, title, description?, status: TaskStatus, priority: TaskPriority, assigneeId?, creatorId, projectId, dueDate?, createdAt, updatedAt }",
    "Project": "{ id, name, ownerId, memberIds, createdAt }",
    "Notification": "{ id, userId, message, channel: NotificationChannel, read, createdAt }",
    "TaskStatus": "'todo' | 'in_progress' | 'done' | 'cancelled'",
    "TaskPriority": "'high' | 'medium' | 'low'",
    "UserRole": "'admin' | 'member' | 'viewer'",
    "NotificationChannel": "'email' | 'in_app'"
  },
  "env": [],
  "status": "stable",
  "lastModified": "2026-04-14"
}
